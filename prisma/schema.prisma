// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ----------------------
// User & Auth Models
// ----------------------
model User {
  id           String    @id @default(uuid()) @db.Uuid
  mobile       String    @unique
  name         String?
  lastName     String?
  nationalCode String?   @unique
  password     String?   // Optional because initial login might be OTP only
  job          String?
  addresses    Json?     @db.JsonB
  role         Role      @default(USER)
  hashedRefreshToken String? // For Refresh Token mechanism
  reviews      ProductReview[]
  orders       Order[]
  tempBaskets  TempBasket[]
  shoppingList ShoppingListItem[]
  discountCodes              DiscountCode[]
  discountCodeEligibilities  DiscountCodeEligibleUser[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  isDeleted    Boolean   @default(false)
  deletedAt    DateTime?
}

model Otp {
  id        String   @id @default(uuid()) @db.Uuid
  mobile    String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

enum Role {
  USER
  ADMIN
}

// ----------------------
// Discount codes (کدهای تخفیف)
// ----------------------

enum DiscountCodeScope {
  ALL_USERS        // همه کاربران
  SINGLE_USER      // یک کاربر مشخص (userId)
  MULTIPLE_USERS   // چند کاربر مشخص (جدول واسط)
  USER_GROUP       // دسته کاربران (userGroupId — منطق بیزینس بعداً)
}

enum DiscountValueType {
  PERCENT       // درصد تخفیف روی سبد
  FIXED_AMOUNT  // مبلغ ثابت تخفیف (تومان)
}

model DiscountCode {
  id     String @id @default(uuid()) @db.Uuid
  /// کد یکتا (معمولاً uppercase)
  code   String @unique
  title  String?

  scope       DiscountCodeScope
  /// وقتی scope = SINGLE_USER
  userId      String? @db.Uuid
  user        User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  /// وقتی scope = USER_GROUP (جدول گروه بعداً اضافه می‌شود)
  userGroupId String? @db.Uuid

  /// وقتی scope = MULTIPLE_USERS
  eligibleUsers DiscountCodeEligibleUser[]

  valueType      DiscountValueType
  /// درصد (۱–۱۰۰) یا مبلغ ثابت بسته به valueType
  value          Decimal @db.Decimal(12, 2)
  minOrderAmount Decimal? @db.Decimal(12, 2)

  validFrom DateTime
  validTo   DateTime

  /// حداکثر دفعات استفاده در کل (null = نامحدود)
  maxTotalUses Int?
  usedCount    Int  @default(0)

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isDeleted Boolean  @default(false)
  deletedAt DateTime?

  @@index([code])
  @@index([scope])
  @@index([validFrom, validTo])
  @@index([userId])
  @@index([userGroupId])
}

/// کاربرانی که برای کد با scope = MULTIPLE_USERS مجاز به استفاده هستند
model DiscountCodeEligibleUser {
  id             String       @id @default(uuid()) @db.Uuid
  discountCodeId String       @db.Uuid
  discountCode   DiscountCode @relation(fields: [discountCodeId], references: [id], onDelete: Cascade)
  userId         String       @db.Uuid
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([discountCodeId, userId])
  @@index([userId])
}

// ----------------------
// E-commerce Models
// ----------------------

model Category {
  id          String    @id @default(uuid()) @db.Uuid
  title       String
  slug        String    @unique
  description String?
  image       String? // URL from MinIO
  parentId    String?   @db.Uuid
  parent      Category? @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryHierarchy")
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  isDeleted   Boolean   @default(false)
  deletedAt   DateTime?
}

model Collection {
  id          String    @id @default(uuid()) @db.Uuid
  title       String
  slug        String    @unique
  description String?
  image       String? // URL from MinIO
  products    Product[]
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  isDeleted   Boolean   @default(false)
  deletedAt   DateTime?
}

// سایزهای قابل انتخاب در واریانت محصول (مدیریت از پنل ادمین)
model Size {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique // مثلاً 42, XL, M
  order     Int      @default(0) // ترتیب نمایش
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isDeleted Boolean  @default(false)
  deletedAt DateTime?
}

// Dynamic Specifications (e.g., Fabric, Care, Origin)
model SpecificationKey {
  id        String   @id @default(uuid()) @db.Uuid
  key       String   @unique // e.g. "material", "care_instruction"
  label     String // e.g. "جنس پارچه", "نحوه شستشو"
  type      SpecType @default(TEXT)
  options   String[] // For SELECT type
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isDeleted Boolean  @default(false)
  deletedAt DateTime?
}

enum SpecType {
  TEXT
  NUMBER
  SELECT
  MULTI_SELECT
}

model Product {
  id              String   @id @default(uuid()) @db.Uuid
  title           String
  slug            String   @unique
  description     String
  
  // SEO
  metaTitle       String?
  metaDescription String?

  // Media (General product images/video)
  images String[] // URLs stored as array of strings
  video  String? // URL

  // Relations
  categoryId String   @db.Uuid
  category   Category @relation(fields: [categoryId], references: [id])
  collections Collection[]

  // Specifications (JSON with validation against SpecificationKey)
  // Format: { "material": "Cotton", "care": "Hand wash" }
  specifications Json?

  // Stats
  soldCount     Int   @default(0)
  viewCount     Int   @default(0)
  averageRating Float @default(0)
  reviewCount   Int   @default(0)

  // Variants (Size/Color)
  variants ProductVariant[]

  // Social
  reviews ProductReview[]
  shoppingListItems ShoppingListItem[]
  orderItems OrderItem[]

  isActive    Boolean  @default(true)
  isFeatured  Boolean  @default(false) // محصول منتخب
  showInIntro Boolean  @default(false) // نمایش در اینترو
  createdAt  DateTime @default(now())
  updatedAt DateTime @updatedAt
  isDeleted Boolean  @default(false)
  deletedAt DateTime?
}

model ProductVariant {
  id        String  @id @default(uuid()) @db.Uuid
  productId String  @db.Uuid
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  sku String @unique

  // Attributes
  size      String?
  color     String?
  colorCode String? // Hex code for color

  // Pricing & Inventory
  price         Decimal  @db.Decimal(10, 2)
  discountPrice Decimal? @db.Decimal(10, 2)
  discountPercent Int?
  stock         Int      @default(0)

  // Media specific to variant (e.g. Red shirt image)
  images String[]

  // Variant specific specifications (e.g. Waist size for this size)
  specifications Json?

  tempBasketItems TempBasketItem[]
  orderItems      OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isDeleted Boolean  @default(false)
  deletedAt DateTime?
}

model ProductReview {
  id        String  @id @default(uuid()) @db.Uuid
  productId String  @db.Uuid
  product   Product @relation(fields: [productId], references: [id])
  userId    String  @db.Uuid
  user      User    @relation(fields: [userId], references: [id])

  rating  Int // 1-5
  comment String?

  isApproved Boolean @default(false) // Admin approval

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isDeleted Boolean  @default(false)
  deletedAt DateTime?
}

model TempBasket {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     TempBasketItem[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isDeleted Boolean  @default(false)
  deletedAt DateTime?

  @@index([userId])
  @@index([userId, isDeleted])
}

model TempBasketItem {
  id              String        @id @default(uuid()) @db.Uuid
  basketId        String        @db.Uuid
  basket          TempBasket    @relation(fields: [basketId], references: [id], onDelete: Cascade)
  productVariantId String       @db.Uuid
  productVariant  ProductVariant @relation(fields: [productVariantId], references: [id])
  quantity        Int
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  isDeleted       Boolean       @default(false)
  deletedAt       DateTime?

  @@unique([basketId, productVariantId])
  @@index([basketId])
  @@index([productVariantId])
}

// User shopping list (لیست خرید) — separate from cart, persisted per user
model ShoppingListItem {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String   @db.Uuid
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@index([userId])
}

// نظرات کلی برند (تستیمونیال صفحه اصلی) — بدون وابستگی به محصول
model SiteTestimonial {
  id         String   @id @default(uuid()) @db.Uuid
  authorName String   // نام نمایشی نویسنده نظر
  comment    String   // متن نظر
  rating     Int?     // 1-5 اختیاری
  isApproved Boolean  @default(false)
  order      Int      @default(0) // ترتیب نمایش (عدد کمتر = اول)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  isDeleted  Boolean  @default(false)
  deletedAt  DateTime?
}

// Placeholder for Order
enum PaymentStatus {
  PENDING
  PAID
  FAILED
}

enum PaymentProvider {
  ZARINPAL
}

enum PaymentTransactionStatus {
  INITIATED
  PAID
  FAILED
}

model Order {
  id        String   @id @default(uuid()) @db.Uuid
  orderCode String   @unique
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id])
  items     OrderItem[]
  totalAmount Decimal @db.Decimal(10, 2) @default(0)
  discountCode String?
  discountAmount Decimal @db.Decimal(10, 2) @default(0)
  shippingCost Decimal @db.Decimal(10, 2) @default(0)
  payableAmount Decimal @db.Decimal(10, 2) @default(0)
  shippingAddress Json? @db.JsonB
  paymentStatus PaymentStatus @default(PENDING)
  paidAt DateTime?
  payments PaymentTransaction[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isDeleted Boolean  @default(false)
  deletedAt DateTime?
}

model PaymentTransaction {
  id        String   @id @default(uuid()) @db.Uuid
  orderId   String   @db.Uuid
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  provider  PaymentProvider
  status    PaymentTransactionStatus @default(INITIATED)
  amount    Decimal  @db.Decimal(10, 2)
  authority String?  @unique
  refId     String?
  createdAt DateTime @default(now())
  verifiedAt DateTime?
  isDeleted Boolean  @default(false)
  deletedAt DateTime?

  @@index([orderId])
  @@index([provider])
  @@index([status])
}

model OrderItem {
  id               String        @id @default(uuid()) @db.Uuid
  orderId          String        @db.Uuid
  order            Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId        String        @db.Uuid
  product          Product       @relation(fields: [productId], references: [id])
  productVariantId String        @db.Uuid
  productVariant   ProductVariant @relation(fields: [productVariantId], references: [id])
  sku              String
  title            String
  quantity         Int
  unitPrice        Decimal       @db.Decimal(10, 2)
  unitDiscountPrice Decimal?     @db.Decimal(10, 2)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  isDeleted        Boolean       @default(false)
  deletedAt        DateTime?

  @@index([orderId])
  @@index([productId])
  @@index([productVariantId])
}
